<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.LanguageController"
      styleClass="language-screen"
      alignment="CENTER"
      spacing="24"
      prefWidth="480" prefHeight="360">

    <padding>
        <Insets top="60" right="80" bottom="60" left="80"/>
    </padding>

    <Label text="Shopping Cart" styleClass="app-title"/>
    <Label text="Select Language" styleClass="select-language-label"/>

    <ComboBox fx:id="langCombo"
              styleClass="language-combo"
              prefWidth="260"
              maxWidth="Infinity"/>

    <Button text="Confirm"
            styleClass="primary-button"
            prefWidth="260"
            maxWidth="Infinity"
            onAction="#onConfirm"/>

</VBox>
